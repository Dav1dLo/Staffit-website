{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "python-http-server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000", "--directory", "staffit.be"],
      "port": 8000
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "staffit.be", "-p", "3000"],
      "port": 3000
    }
  ]
}
